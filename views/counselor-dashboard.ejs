<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= description %>">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <main>
    <section class="dashboard-page">
      <div class="container">
        <div class="dashboard-header">
          <h1>Counselor Dashboard</h1>
          <p>Review assigned student reports and manage guidance session status.</p>
        </div>

        <div class="profile-card">
          <div class="profile-avatar" id="counselorInitials">CC</div>
          <div class="profile-details">
            <h2 id="counselorName">Counselor Name</h2>
            <p id="counselorEmail" style="color: var(--text-muted); margin-bottom: 0.75rem;">counselor@email.com</p>
            <div class="profile-meta">
              <span class="profile-tag" id="counselorSpec">Specialization</span>
              <span class="profile-tag" id="counselorExperience">Experience</span>
            </div>
          </div>
        </div>

        <h2 style="font-size: 1.25rem; color: var(--primary-blue); margin-bottom: 1rem;">Assigned Students</h2>

        <div class="counselor-table-wrap">
          <table class="counselor-table">
            <thead>
              <tr>
                <th>Student Name</th>
                <th>Assessment Date</th>
                <th>Recommended Path</th>
                <th>Report</th>
                <th>Session Status</th>
              </tr>
            </thead>
            <tbody id="assignmentsBody"></tbody>
          </table>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer', { footerPlatformLinks: [{ href: '/', label: 'Home' }, { href: '/about', label: 'About Us' }] }) %>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="/js/questions.js"></script>
  <script src="/js/app.js"></script>
  <script src="/js/counselor.js"></script>
</body>
</html>
