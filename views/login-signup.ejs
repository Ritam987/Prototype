<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= description %>">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <% if (typeof showPreloader !== 'undefined' && showPreloader) { %>
  <div class="preloader" id="preloader">
    <div class="preloader-logo">CareerPath</div>
    <div class="preloader-spinner"></div>
    <p class="preloader-text">Preparing your career journey...</p>
  </div>
  <% } %>

  <%- include('partials/navbar') %>

  <main>
    <section class="auth-page">
      <div class="container">
        <div class="auth-card">
          <h1 id="authTitle">Create Your Account</h1>
          <p class="subtitle" id="authSubtitle">Join our platform and unlock personalized career guidance.</p>

          <button type="button" class="google-btn" id="googleAuthBtn">
            <img src="/assets/google-logo.svg" alt="Google logo">
            Sign in with Google
          </button>

          <div class="divider">or continue with email</div>

          <form id="authForm" action="/auth/register" method="POST">
            <div class="form-group" id="roleSelectGroup">
              <label for="roleSelect">I am a</label>
              <select id="roleSelect" name="role" required>
                <option value="student">I am a Student</option>
                <option value="counselor">I am a Career Counselor</option>
              </select>
            </div>

            <div id="dynamicFields"></div>

            <button type="submit" class="btn btn-secondary btn-block" id="authSubmitBtn">Create Account</button>
          </form>

          <p class="form-toggle">
            <a href="#" id="toggleAuthMode">Already have an account? Switch to Login</a>
          </p>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="/js/app.js"></script>
  <script src="/js/auth.js"></script>
</body>
</html>
