# Server Configuration
PORT=3000
NODE_ENV=development

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Session Configuration
# Generate a secure random string (min 32 characters)
SESSION_SECRET=your_random_secret_key_min_32_characters

# OAuth Configuration
# IMPORTANT FOR PRODUCTION:
# - For Vercel: Leave this EMPTY (it will auto-detect from the request)
# - For local development: http://localhost:3000
# - The app will automatically use the correct production URL when deployed
OAUTH_REDIRECT_URL=

# PostgreSQL Configuration (for local Supabase development)
POSTGRES_DB=careerpath
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_PORT=54322
SUPABASE_POSTGRES_IMAGE=supabase/postgres:15.14.1.138_amd64
